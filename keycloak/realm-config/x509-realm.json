{
  "realm": "x509-demo",
  "enabled": true,
  "displayName": "X.509 Certificate Demo",
  "displayNameHtml": "<strong>X.509 Certificate Demo</strong>",
  "sslRequired": "external",
  "registrationAllowed": true,
  "registrationEmailAsUsername": false,
  "rememberMe": true,
  "verifyEmail": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 5,
  "defaultRole": {
    "name": "default-roles-x509-demo",
    "composite": true
  },
  "roles": {
    "realm": [
      {
        "name": "user",
        "description": "Regular user role"
      },
      {
        "name": "admin",
        "description": "Administrator role"
      },
      {
        "name": "cert-manager",
        "description": "Can manage own certificates"
      }
    ]
  },
  "users": [
    {
      "username": "testuser",
      "enabled": true,
      "emailVerified": true,
      "email": "testuser@example.com",
      "firstName": "Test",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "testuser123",
          "temporary": false
        }
      ],
      "realmRoles": ["user", "cert-manager"]
    },
    {
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "email": "admin@example.com",
      "firstName": "Admin",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ],
      "realmRoles": ["user", "admin", "cert-manager"]
    }
  ],
  "clients": [
    {
      "clientId": "x509-demo-app",
      "name": "X.509 Demo Application",
      "description": "Demo application for X.509 certificate authentication",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "demo-app-secret",
      "redirectUris": [
        "http://localhost:8080/*",
        "https://localhost/*",
        "https://keycloak.local/*"
      ],
      "webOrigins": [
        "http://localhost:8080",
        "https://localhost",
        "https://keycloak.local"
      ],
      "publicClient": false,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "fullScopeAllowed": true,
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ],
      "protocolMappers": [
        {
          "name": "x509-public-key-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "x509_certificate_public_key",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "x509_public_key",
            "jsonType.label": "String",
            "multivalued": "true"
          }
        },
        {
          "name": "x509-subject-dn-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "x509_certificate_subject_dn",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "x509_subject_dn",
            "jsonType.label": "String",
            "multivalued": "true"
          }
        }
      ]
    },
    {
      "clientId": "cert-api-client",
      "name": "Certificate API Client",
      "description": "Service account for certificate management API",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "cert-api-secret",
      "publicClient": false,
      "protocol": "openid-connect",
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "fullScopeAllowed": true
    }
  ],
  "authenticationFlows": [
    {
      "alias": "x509-browser-flow",
      "description": "Browser flow with X.509 certificate support",
      "providerId": "basic-flow",
      "topLevel": true,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticator": "auth-cookie",
          "authenticatorFlow": false,
          "requirement": "ALTERNATIVE",
          "priority": 10,
          "userSetupAllowed": false,
          "autheticatorFlow": false
        },
        {
          "authenticator": "auth-spnego",
          "authenticatorFlow": false,
          "requirement": "DISABLED",
          "priority": 20,
          "userSetupAllowed": false,
          "autheticatorFlow": false
        },
        {
          "authenticator": "identity-provider-redirector",
          "authenticatorFlow": false,
          "requirement": "ALTERNATIVE",
          "priority": 25,
          "userSetupAllowed": false,
          "autheticatorFlow": false
        },
        {
          "authenticatorFlow": true,
          "requirement": "ALTERNATIVE",
          "priority": 30,
          "flowAlias": "x509-browser-forms",
          "userSetupAllowed": false,
          "autheticatorFlow": true
        }
      ]
    },
    {
      "alias": "x509-browser-forms",
      "description": "Username, password, and X.509 certificate form",
      "providerId": "basic-flow",
      "topLevel": false,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticator": "x509-user-attribute-authenticator",
          "authenticatorFlow": false,
          "requirement": "ALTERNATIVE",
          "priority": 5,
          "userSetupAllowed": false,
          "autheticatorFlow": false
        },
        {
          "authenticator": "auth-x509-client-username-form",
          "authenticatorFlow": false,
          "requirement": "ALTERNATIVE",
          "priority": 10,
          "userSetupAllowed": false,
          "autheticatorFlow": false,
          "authenticatorConfig": "x509-config"
        },
        {
          "authenticator": "auth-username-password-form",
          "authenticatorFlow": false,
          "requirement": "ALTERNATIVE",
          "priority": 20,
          "userSetupAllowed": false,
          "autheticatorFlow": false
        }
      ]
    }
  ],
  "authenticatorConfig": [
    {
      "alias": "x509-config",
      "config": {
        "x509-cert-auth.mapper-selection.user-attribute-name": "x509_certificate_subject_dn",
        "x509-cert-auth.mapping-source-selection": "Subject's Common Name",
        "x509-cert-auth.regular-expression": "(.*)",
        "x509-cert-auth.crl-checking-enabled": "false",
        "x509-cert-auth.ocsp-checking-enabled": "false",
        "x509-cert-auth.timestamp-validation-enabled": "true",
        "x509-cert-auth.confirmation-page-disallowed": "false",
        "x509-cert-auth.revalidate-certificate-enabled": "false"
      }
    }
  ],
  "browserFlow": "x509-browser-flow",
  "attributes": {
    "frontendUrl": "https://localhost",
    "acr.loa.map": "{\"gold\":\"2\",\"silver\":\"1\"}",
    "userProfileEnabled": "true"
  },
  "userManagedAccessAllowed": true,
  "eventsEnabled": true,
  "eventsListeners": ["jboss-logging"],
  "adminEventsEnabled": true,
  "adminEventsDetailsEnabled": true
}
