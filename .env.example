# PostgreSQL (Keycloak)
POSTGRES_DB=keycloak
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=keycloak_password          # CHANGE in production

# Keycloak admin
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin                # CHANGE in production

# Truststore (Java keystore for CA certificates)
TRUSTSTORE_PASSWORD=changeit                 # CHANGE in production

# Realm configuration (used by keycloak-config-cli)
REALM_NAME=x509-demo
CLIENT_ID=x509-demo-app

# PostgreSQL (OpenFGA)
OPENFGA_POSTGRES_DB=openfga
OPENFGA_POSTGRES_USER=openfga
OPENFGA_POSTGRES_PASSWORD=openfga_password   # CHANGE in production
